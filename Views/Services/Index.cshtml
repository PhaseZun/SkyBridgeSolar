@{
    ViewData["Title"] = "Our Engineering & Operational Services";
}

<!-- HEADER COVER BANNER -->
<section class="services-hero text-center text-white py-5 d-flex align-items-center">
    <div class="container py-4 z-1">
        <span class="badge bg-warning text-dark mb-2 fw-bold px-3 py-2 text-uppercase tracking-wider">Scale Your Solar Operations</span>
        <h1 class="display-4 fw-extrabold text-white mb-3">Enterprise Solar Back-Office Solutions</h1>
        <p class="lead text-white-50 max-w-xl mx-auto mb-0">
            Discover how Sky Bridge Solar accelerates turnaround speed, slashes overhead costs, and ensures 97.9% first-time AHJ approval rates.
        </p>
    </div>
    <div class="services-hero-overlay"></div>
</section>

<!-- SERVICE SEGMENT BLOCKS -->
<section class="py-5 bg-light">
    <div class="container py-4">

        <!-- 1. SALES PROPOSALS -->
        <div id="proposals" class="row align-items-center g-5 mb-5 pb-5 border-bottom">
            <div class="col-lg-6">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-file-earmark-bar-graph fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Solar Sales Proposals & Production Reports</h2>
                <p class="text-muted">
                    Win more business with precision data. We generate clean, modern customer proposals mapping highly optimized production simulations, system degradation curves, and comprehensive configuration charts.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Custom shading and obstacle mitigation analysis</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Detailed 3D layout simulation graphs</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Financial ROI and energy offset projections</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Inquire About Proposals</button>
            </div>
            <div class="col-lg-6">
                <img src="/images/service-proposals.jpg" alt="Solar Sales Proposals" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

        <!-- 2. SITE ASSESSMENT -->
        <div id="assessment" class="row align-items-center g-5 mb-5 pb-5 border-bottom flex-css-reverse">
            <div class="col-lg-6 order-lg-2">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-geo-alt fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Site Survey & Feasibility Assessment</h2>
                <p class="text-muted">
                    Eliminate field execution risks. We conduct meticulous evaluations of your raw roof space data, mapping local fire codes, set-backs, structural orientations, and electrical constraints prior to core configuration mapping.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Comprehensive roof-type asset integrity evaluation</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Electrical service panel layout structural cross-checking</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> High-resolution layout optimization configurations</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Book Survey Review</button>
            </div>
            <div class="col-lg-6 order-lg-1">
                <img src="/images/service-assessment.jpg" alt="Site Survey & Assessment" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

        <!-- 3. PERMIT DESIGN & PLAN SETS -->
        <div id="permit" class="row align-items-center g-5 mb-5 pb-5 border-bottom">
            <div class="col-lg-6">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-layers fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Permit Design & Full Plan Sets</h2>
                <p class="text-muted">
                    Accelerate your physical operational workflows. Our engineering core sets up highly comprehensive, installation-ready construction plan sets modeled systematically according to regional building parameters.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Detailed Three-Line & Single-Line Diagrams (SLD)</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Custom electrical load calculations and wire sizing data</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Racking layout plans and ballast calculation setups</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Request Plan Set Demo</button>
            </div>
            <div class="col-lg-6">
                <img src="/images/service-permit.jpg" alt="Permit Design Plan Sets" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

        <!-- 4. PROFESSIONAL ENGINEERING PE REVIEW -->
        <div id="pe" class="row align-items-center g-5 mb-5 pb-5 border-bottom flex-css-reverse">
            <div class="col-lg-6 order-lg-2">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-award fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Professional Engineering (PE) Review & Stamps</h2>
                <p class="text-muted">
                    Ensure bulletproof risk validation. We support multi-regional installation networks with official structural and electrical Professional Engineering certifications, detailed calculations, and official wet/digital stamps.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Certified electrical distribution network safety cross-checks</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Detailed roof layout structural wind & snow load calculations</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Validated multi-state licensed engineering seals</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Get PE Stamps</button>
            </div>
            <div class="col-lg-6 order-lg-1">
                <img src="/images/service-pe.jpg" alt="PE Engineering Stamp Review" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

        <!-- 5. UTILITY INTERCONNECTION -->
        <div id="interconnection" class="row align-items-center g-5 mb-5 pb-5 border-bottom">
            <div class="col-lg-6">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-file-check fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Utility Interconnection Management</h2>
                <p class="text-muted">
                    Bypass complex administrative roadblocks. Our team coordinates directly with local utility providers to submit, handle, and clear all necessary net-metering structures and interconnection authorizations.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Complete net-metering operational application management</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Fast corrections handling directly with electrical utility grids</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Complete tracking till formal PTO (Permission to Operate)</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Simplify Interconnection</button>
            </div>
            <div class="col-lg-6">
                <img src="/images/service-utility.jpg" alt="Utility Interconnection Management" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

        <!-- 6. PERMITTING & AHJ SUPPORT -->
        <div id="support" class="row align-items-center g-5 flex-css-reverse">
            <div class="col-lg-6 order-lg-2">
                <div class="icon-box-large bg-primary text-white mb-3 shadow-sm"><i class="bi bi-shield-check fs-2"></i></div>
                <h2 class="fw-bold text-dark mb-3">Permitting & AHJ Revision Support</h2>
                <p class="text-muted">
                    Keep project pipelines moving cleanly. If local building jurisdictions (AHJ) request changes, our engineers handle corrections and revisions inside 24 hours to clear roadblocks instantly.
                </p>
                <ul class="list-unstyled text-secondary mb-4 space-y-2">
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Rapid structural design adjustments</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> 100% adherence to active National Electrical Code (NEC) rules</li>
                    <li><i class="bi bi-check-circle-fill text-success me-2"></i> Dedicated engineering tracking throughout municipal cycles</li>
                </ul>
                <button class="btn btn-primary px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#consultationModal">Contact Operations Support</button>
            </div>
            <div class="col-lg-6 order-lg-1">
                <img src="/images/service-support.jpg" alt="AHJ Permitting Support" class="img-fluid rounded-3 shadow border w-100 object-fit-cover" style="height: 360px;">
            </div>
        </div>

    </div>
</section>

<!-- LEADS CONSULTATION MODAL -->
<div class="modal fade" id="consultationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-dark text-white border-0">
                <h5 class="modal-title fw-bold">Connect With Our Engineering Team</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" action="/Contact/Submit">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Corporate Contact Name</label>
                        <input type="text" class="form-control" name="Name" required placeholder="Sushant Pawar">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Business Email Address</label>
                        <input type="email" class="form-control" name="Email" required placeholder="s.pawar@skybridgesolar.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-secondary">Required Workflow Action</label>
                        <select class="form-select" name="ServiceSegment">
                            <option value="Proposals">Sales Proposals Integration</option>
                            <option value="PermitDesign">Full Construction Plan Sets</option>
                            <option value="PEStamps">PE Structural Stamps Evaluation</option>
                            <option value="Interconnection">PTO Utility Interconnection Documentation</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-light p-3 border-0">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Submit Workflow Request</button>
                </div>
            </form>
        </div>
    </div>
</div>