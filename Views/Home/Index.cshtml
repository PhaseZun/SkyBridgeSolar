                <div class="carousel-caption custom-caption text-start">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-7">
                                <span class="badge bg-warning text-dark mb-3 fw-bold px-3 py-2 text-uppercase tracking-wider">Industrial Strength</span>
