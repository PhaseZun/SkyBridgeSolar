            <!-- Slide 1 -->
            <div class="carousel-item active h-100">
                <div class="slider-overlay"></div>
                <img src="/images/solar-slide1.jpg" class="d-block w-100 h-100 slider-img" alt="Solar Energy Solutions">
                <div class="carousel-caption custom-caption text-start">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-7">
